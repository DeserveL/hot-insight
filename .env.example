# 网站关注标记。命中的热点会进入网站数据和 AI 洞察。
TRACK_TAGS=爆,沸,热

# 推送标记。默认只实时推送 爆、沸；热 只在网站展示。
ALERT_TAGS=爆,沸

# 同标题再次出现时，超过对应小时数视为新的热点。
TAG_RECURRENCE_HOURS=爆:12,沸:12,热:24

# 每轮最多推送主题数
MAX_TOPICS_PER_RUN=10

# API 后台调度周期，单位分钟
SCHEDULE_MINUTES=30

# 微博数据源顺序：默认优先使用微博官方公开页面，失败后切换备用源
WEIBO_SOURCE_ORDER=weibo_official,xk,xunjinlu,xxapi,nsuuu

# 数据源请求超时。官方源可单独调节榜单、游客初始化和详情映射请求。
FETCH_TIMEOUT_SECONDS=15
WEIBO_OFFICIAL_TIMEOUT_SECONDS=15
WEIBO_OFFICIAL_VISITOR_TIMEOUT_SECONDS=15
WEIBO_OFFICIAL_REALTIME_TIMEOUT_SECONDS=15
WEIBO_OFFICIAL_MAX_RETRIES=2

# SQLite 数据库路径；data/ 是持久化业务数据目录，需要备份
DATABASE_PATH=data/hot_insight.sqlite3

# 网站公开地址。配置后通知按钮优先跳到网站详情页。
PUBLIC_SITE_URL=http://localhost:3000

# 通知渠道。支持 wecom、telegram，多个用英文逗号分隔。
NOTIFY_CHANNELS=wecom,telegram

# FastAPI 容器是否启动后台采集调度
API_SCHEDULER_ENABLED=true

# 日志等级
LOG_LEVEL=INFO

# 日志文件。控制台日志用于实时查看，文件日志用于持久化排障。
LOG_FILE_ENABLED=true
LOG_FILE_PATH=data/logs/hot-insight.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=7

# 健康告警冷却时间，单位分钟
HEALTH_ALERT_COOLDOWN_MINUTES=180
WECOM_HEALTH_ALERTS=true

# 企业微信应用配置
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=
WECOM_TO_USER=@all
WECOM_ORIGIN=https://qyapi.weixin.qq.com

# 业务热点通知类型：mpnews 为单条图文卡片；markdown 为文本降级模式
WECOM_MESSAGE_TYPE=mpnews
WECOM_MPNEWS_AUTHOR=热点洞察

# mpnews 优先使用微博官方详情页头图；无头图时使用企业微信素材库 hot.jpeg。
# 如已知素材 media_id，可直接填写 WECOM_DEFAULT_COVER_MEDIA_ID。
WECOM_DEFAULT_COVER_MEDIA_ID=
WECOM_DEFAULT_COVER_NAME=hot.jpeg
NOTIFICATION_DEFAULT_COVER=backend/app/assets/notification-covers/default-cover.png

# Telegram 频道推送。需要先把 Bot 加为频道管理员。
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_API_BASE_URL=https://api.telegram.org
TG_PARSE_MODE=HTML
TG_TIMEOUT_SECONDS=15
TG_MAX_RETRIES=3

# AI 热搜详情。需要选择支持联网搜索的 OpenAI 兼容 Chat Completions 模型。
AI_DETAIL_ENABLED=true
AI_DETAIL_BASE_URL=https://your-api.example.com/v1
AI_DETAIL_API_KEY=
AI_DETAIL_MODEL=
AI_DETAIL_API_MODE=chat_completions
AI_DETAIL_MAX_RETRIES=3
AI_DETAIL_TIMEOUT_SECONDS=60
AI_DETAIL_TEMPERATURE=0.2

# 默认传给 /chat/completions 的 web_search_options；如果兼容接口不支持该字段，设置为空：
# AI_DETAIL_WEB_SEARCH_OPTIONS=
AI_DETAIL_WEB_SEARCH_OPTIONS={}

# 可选：兼容中转服务的自定义请求字段。不能覆盖 model/messages/temperature 等核心字段。
AI_DETAIL_EXTRA_PAYLOAD_JSON={}
